{
  "name": "@fnode/rpc",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "bun": "./src/index.ts"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "bun": "./src/server/index.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fnode/core": "workspace:*",
    "@fnode/fusion": "workspace:*"
  },
  "devDependencies": {}
}
